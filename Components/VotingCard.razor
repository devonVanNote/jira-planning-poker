<div class="voting-card @(IsSelected ? "voting-card--selected" : "") @(Disabled ? "voting-card--disabled" : "")"
     @onclick="HandleClick"
     data-value="@Value"
     title="Vote @Value (key @KeyLabel)">
    <span class="voting-card__value">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string KeyLabel { get; set; } = "";
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<string> OnSelect { get; set; }

    private async Task HandleClick()
    {
        if (!Disabled) await OnSelect.InvokeAsync(Value);
    }
}
